# ── Banxico SIE API ───────────────────────────────────────────────────────
# Solicita tu token en: https://www.banxico.org.mx/SieAPIRest/service/v1/
# Es gratuito, se genera una sola vez y permite 40,000 consultas/día
BANXICO_TOKEN=

# ── INEGI API ─────────────────────────────────────────────────────────────
# Solicita tu token en: https://www.inegi.org.mx/servicios/api_indicadores.html
# Requiere registro con correo, es gratuito
INEGI_TOKEN=

# ── Gmail (envío automático) ──────────────────────────────────────────────
# Usa una App Password, NO tu contraseña normal de Gmail
# Cómo generar una: Google Account → Seguridad → Verificación en 2 pasos → Contraseñas de aplicaciones
GMAIL_USER=tu_correo@gmail.com
GMAIL_APP_PASSWORD=


# ── Configuración del scheduler ──────────────────────────────────────────
# Hora de envío diario en formato HH:MM (24h, hora local)
HORA_ENVIO=07:30
